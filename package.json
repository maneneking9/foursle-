{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --port=3000 --host=0.0.0.0\"",
    "server": "tsx watch server.ts",
    "server:turso": "tsx watch server-turso.ts",
    "server:prod": "node --import tsx server-prod.ts",
    "start": "node --import tsx server-prod.ts",
    "build": "vite build",
    "build:prod": "vite build && npm run server:prod",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "init-db": "tsx init-db.ts",
    "vercel-build": "vite build",
    "postinstall": "vite build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@libsql/client": "^0.17.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "devDependencies": {}
}